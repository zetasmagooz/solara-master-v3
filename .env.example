# App
APP_NAME=Solara Backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (async + sync)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/solara_dev
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/solara_dev
DB_TIMEZONE=America/Mexico_City

# Auth (RS256)
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# OpenAI (NL2SQL + Interpret)
OPENAI_API_KEY=
OPENAI_MODEL_NL2SQL=gpt-4.1-mini
OPENAI_MODEL_INTERPRET=gpt-4.1-mini
OPENAI_MAX_ROWS=500

# Gemini TTS
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Leda

# Weather
WEATHER_API_KEY=
